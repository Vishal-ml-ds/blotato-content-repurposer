# Blotato — used for YouTube extraction, visual generation, publishing
# Get key: https://blotato.com (paid)
BLOTATO_API_KEY=your_blotato_key_here

# Euri — used for LLM post generation (LinkedIn / X / Instagram caption)
# Get key (free 200K tokens/day): https://euron.one
EURI_API_KEY=your_euri_key_here

# Model name passed to Euri (OpenAI-compatible chat completions)
# Supported: gpt-5.4-mini (fast+cheap), gemini-2.5-flash, claude-sonnet-4-6
LLM_MODEL=gpt-5.4-mini

# Safety switch — when true, run.py skips Blotato calls and uses seed text.
# Set to false ONLY when you have real keys and want to spend Blotato credits.
DRY_RUN_DEFAULT=true
